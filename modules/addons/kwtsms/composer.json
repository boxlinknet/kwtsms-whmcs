{
    "name": "kwtsms/kwtsms-whmcs",
    "description": "kwtSMS WHMCS Addon Module - Automated SMS notifications via kwtsms.com",
    "type": "library",
    "license": "MIT",
    "require": {
        "php": ">=8.2",
        "kwtsms/kwtsms-php": "^1.0"
    },
    "require-dev": {
        "phpstan/phpstan": "^1.10",
        "phpunit/phpunit": "^10.5",
        "squizlabs/php_codesniffer": "^3.8"
    },
    "autoload": {
        "psr-4": {
            "KwtSMS\\WHMCS\\": "lib/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "KwtSMS\\WHMCS\\Tests\\": "tests/"
        }
    },
    "scripts": {
        "test": "phpunit --testsuite Unit",
        "test-api": "phpunit --testsuite Api",
        "test-all": "phpunit",
        "lint": "phpstan analyse && phpcs --standard=phpcs.xml"
    },
    "config": {
        "optimize-autoloader": true,
        "sort-packages": true
    }
}
